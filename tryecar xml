<?xml version="1.0" encoding="UTF-8"?>
<jcr:root
    xmlns:sling="http://sling.apache.org/jcr/sling/1.0"
    xmlns:cq="http://www.day.com/jcr/cq/1.0"
    xmlns:jcr="http://www.jcp.org/jcr/1.0"
    xmlns:nt="http://www.jcp.org/jcr/nt/1.0"
    jcr:primaryType="nt:unstructured"
    jcr:title="TrueCar Search"
    sling:resourceType="cq/gui/components/authoring/dialog">

    <content
        jcr:primaryType="nt:unstructured"
        sling:resourceType="granite/ui/components/coral/foundation/container">

        <items jcr:primaryType="nt:unstructured">
            <tabs
                jcr:primaryType="nt:unstructured"
                sling:resourceType="granite/ui/components/coral/foundation/tabs"
                maximized="{Boolean}true">

                <items jcr:primaryType="nt:unstructured">

                    <newCar
                        jcr:primaryType="nt:unstructured"
                        jcr:title="New Car"
                        sling:resourceType="granite/ui/components/coral/foundation/container">

                        <items jcr:primaryType="nt:unstructured">
                            <newCarTitle
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                fieldLabel="New Car Title"
                                name="./newCarTitle"
                                value="Price a new car"/>

                            <newCarButtonLabel
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                fieldLabel="New Car Button Label"
                                name="./newCarButtonLabel"
                                value="Shop new cars"/>

                            <newCarBaseUrl
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                fieldLabel="New Car Base URL"
                                name="./newCarBaseUrl"
                                emptyText="https://..."
                                required="{Boolean}true"/>
                        </items>
                    </newCar>

                    <usedCar
                        jcr:primaryType="nt:unstructured"
                        jcr:title="Used Car"
                        sling:resourceType="granite/ui/components/coral/foundation/container">

                        <items jcr:primaryType="nt:unstructured">
                            <usedCarTitle
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                fieldLabel="Used Car Title"
                                name="./usedCarTitle"
                                value="Price a used car"/>

                            <usedCarButtonLabel
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                fieldLabel="Used Car Button Label"
                                name="./usedCarButtonLabel"
                                value="Shop used cars"/>

                            <usedCarBaseUrl
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                fieldLabel="Used Car Base URL"
                                name="./usedCarBaseUrl"
                                emptyText="https://..."
                                required="{Boolean}true"/>
                        </items>
                    </usedCar>

                </items>
            </tabs>
        </items>
    </content>
</jcr:root>